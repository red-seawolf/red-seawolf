# Copy to .env (or just export these) — all optional.
PORT=3000

# Path to a Chromium/Chrome executable for Playwright.
# Leave unset to use the default; on the pre-provisioned environment it is
# /opt/pw-browsers/chromium.
# CHROMIUM_PATH=/usr/bin/chromium

# Override the browser User-Agent used for scraping.
# SCRAPER_UA=Mozilla/5.0 (...)
